{
  "$schema": "vscode://schemas/color-theme",
  "name": "GoLand Exact Dark",
  "type": "dark",
  "semanticHighlighting": true,
  "colors": {
    "foreground": "#bcbec4",
    "focusBorder": "#00000000",
    "contrastBorder": "#00000000",
    "contrastActiveBorder": "#00000000",

    "titleBar.activeBackground": "#2b2d30",
    "titleBar.activeForeground": "#d0d2d6",
    "titleBar.inactiveBackground": "#2b2d30",
    "titleBar.inactiveForeground": "#91959d",
    "titleBar.border": "#3a3c3f",

    "activityBar.background": "#2b2d30",
    "activityBar.foreground": "#c9ccd2",
    "activityBar.inactiveForeground": "#7c818a",
    "activityBar.activeBorder": "#3574f0",
    "activityBar.border": "#3a3c3f",
    "activityBarBadge.background": "#4e8df6",
    "activityBarBadge.foreground": "#ffffff",

    "sideBar.background": "#2b2d30",
    "sideBar.foreground": "#cfd2d8",
    "sideBar.border": "#3a3c3f",
    "sideBarTitle.foreground": "#f1f3f5",
    "sideBarSectionHeader.background": "#2b2d30",
    "sideBarSectionHeader.foreground": "#f1f3f5",
    "sideBarSectionHeader.border": "#3a3c3f",

    "list.activeSelectionBackground": "#5a5d66",
    "list.activeSelectionForeground": "#f1f3f5",
    "list.inactiveSelectionBackground": "#555860",
    "list.inactiveSelectionForeground": "#eef1f4",
    "list.focusBackground": "#5a5d66",
    "list.focusForeground": "#f1f3f5",
    "list.hoverBackground": "#404348",
    "list.hoverForeground": "#f1f3f5",
    "list.highlightForeground": "#f1f3f5",
    "list.dropBackground": "#474b52",
    "tree.indentGuidesStroke": "#3b3e43",

    "editor.background": "#1e1f22",
    "editor.foreground": "#bcbec4",
    "editorLineNumber.foreground": "#4a505a",
    "editorLineNumber.activeForeground": "#868b94",
    "editorCursor.foreground": "#c9ccd2",
    "editor.selectionBackground": "#214283",
    "editor.inactiveSelectionBackground": "#43454a",
    "editor.lineHighlightBackground": "#23252a",
    "editor.lineHighlightBorder": "#00000000",
    "editor.wordHighlightBackground": "#31353d",
    "editor.wordHighlightStrongBackground": "#21428355",
    "editor.selectionHighlightBackground": "#31353d",
    "editor.findMatchBackground": "#355d94",
    "editor.findMatchBorder": "#5f93e6",
    "editor.findMatchHighlightBackground": "#2d394d",
    "editor.findMatchHighlightBorder": "#3d587d",
    "editorWhitespace.foreground": "#2f3338",
    "editorIndentGuide.background1": "#2c3035",
    "editorIndentGuide.activeBackground1": "#4d525b",
    "editorBracketMatch.background": "#2f3540",
    "editorBracketMatch.border": "#5f6670",
    "editorLink.activeForeground": "#589df6",
    "editorHoverWidget.background": "#2b2d30",
    "editorHoverWidget.border": "#45484d",
    "editorSuggestWidget.background": "#2b2d30",
    "editorSuggestWidget.foreground": "#c7cad1",
    "editorSuggestWidget.selectedBackground": "#4b4d52",
    "editorSuggestWidget.highlightForeground": "#64a3df",
    "editorWidget.background": "#2b2d30",
    "editorWidget.border": "#45484d",
    "editorGutter.background": "#1f2023",
    "editorError.foreground": "#db5c5c",
    "editorWarning.foreground": "#d6b85a",
    "editorInfo.foreground": "#4f9eed",
    "editorHint.foreground": "#6aab73",
    "editorOverviewRuler.border": "#00000000",
    "editorOverviewRuler.errorForeground": "#db5c5c",
    "editorOverviewRuler.warningForeground": "#d6b85a",
    "editorOverviewRuler.infoForeground": "#4f9eed",
    "editorOverviewRuler.findMatchForeground": "#5f93e6",
    "editorCodeLens.foreground": "#7b8088",
    "editorInlayHint.foreground": "#7f848e",
    "editorInlayHint.background": "#00000000",
    "editorInlayHint.typeForeground": "#7f848e",
    "editorInlayHint.typeBackground": "#00000000",
    "editorInlayHint.parameterForeground": "#7f848e",
    "editorInlayHint.parameterBackground": "#00000000",
    "editorLightBulb.foreground": "#ffd866",
    "editorLightBulbAutoFix.foreground": "#6aab73",
    "editorStickyScroll.background": "#1f2023",
    "editorStickyScrollHover.background": "#26282e",

    "editorGroup.border": "#3a3c3f",
    "editorGroupHeader.tabsBackground": "#2b2d30",
    "editorGroupHeader.noTabsBackground": "#2b2d30",
    "editorGroupHeader.tabsBorder": "#3a3c3f",

    "tab.border": "#3a3c3f",
    "tab.activeBackground": "#2b2d30",
    "tab.activeForeground": "#e3e5e8",
    "tab.activeBorderTop": "#4e8df6",
    "tab.inactiveBackground": "#1f2023",
    "tab.inactiveForeground": "#9ea3ab",
    "tab.hoverBackground": "#313338",
    "tab.hoverForeground": "#eceef2",
    "tab.unfocusedActiveForeground": "#c7cad0",
    "tab.unfocusedInactiveForeground": "#8e9299",

    "breadcrumb.background": "#1f2023",
    "breadcrumb.foreground": "#80858d",
    "breadcrumb.activeSelectionForeground": "#cfd2d8",
    "breadcrumb.focusForeground": "#cfd2d8",

    "panel.background": "#2b2d30",
    "panel.border": "#3a3c3f",
    "panelTitle.activeForeground": "#eceef2",
    "panelTitle.inactiveForeground": "#9ba0a8",
    "panelTitle.activeBorder": "#4e8df6",

    "statusBar.background": "#2b2d30",
    "statusBar.foreground": "#9da2ab",
    "statusBar.border": "#3a3c3f",
    "statusBar.noFolderBackground": "#2b2d30",
    "statusBar.noFolderBorder": "#3a3c3f",
    "statusBarItem.hoverBackground": "#393b40",
    "statusBarItem.activeBackground": "#43454a",
    "statusBarItem.prominentBackground": "#393b40",
    "statusBarItem.prominentHoverBackground": "#43454a",

    "menu.background": "#2b2d30",
    "menu.foreground": "#ced0d6",
    "menu.selectionBackground": "#43454a",
    "menu.selectionForeground": "#f1f3f5",
    "menu.separatorBackground": "#45484d",

    "dropdown.background": "#2b2d30",
    "dropdown.foreground": "#ced0d6",
    "dropdown.border": "#4b4f55",
    "input.background": "#3a3d42",
    "input.foreground": "#d7dae0",
    "input.border": "#4b4f55",
    "input.placeholderForeground": "#7e838c",

    "button.background": "#4e8df6",
    "button.foreground": "#ffffff",
    "button.hoverBackground": "#6ea4ff",
    "button.secondaryBackground": "#3a3d42",
    "button.secondaryForeground": "#d7dae0",
    "button.secondaryHoverBackground": "#45484d",

    "badge.background": "#4e8df6",
    "badge.foreground": "#ffffff",
    "progressBar.background": "#4e8df6",

    "scrollbar.shadow": "#00000055",
    "scrollbarSlider.background": "#ffffff14",
    "scrollbarSlider.hoverBackground": "#ffffff22",
    "scrollbarSlider.activeBackground": "#ffffff30",

    "minimap.background": "#1f2023",
    "minimap.selectionHighlight": "#21428355",
    "minimap.findMatchHighlight": "#5f93e6",
    "minimap.errorHighlight": "#db5c5c",
    "minimap.warningHighlight": "#d6b85a",

    "terminal.background": "#1f2023",
    "terminal.foreground": "#bcbec4",
    "terminal.ansiBlack": "#1f2023",
    "terminal.ansiBlue": "#589df6",
    "terminal.ansiBrightBlack": "#6f747c",
    "terminal.ansiBrightBlue": "#7cb7ff",
    "terminal.ansiBrightCyan": "#7ad0f7",
    "terminal.ansiBrightGreen": "#89d185",
    "terminal.ansiBrightMagenta": "#d7a6ff",
    "terminal.ansiBrightRed": "#ff7b72",
    "terminal.ansiBrightWhite": "#f1f3f5",
    "terminal.ansiBrightYellow": "#f2d06b",
    "terminal.ansiCyan": "#56b6c2",
    "terminal.ansiGreen": "#6aab73",
    "terminal.ansiMagenta": "#b78cff",
    "terminal.ansiRed": "#db5c5c",
    "terminal.ansiWhite": "#bcbec4",
    "terminal.ansiYellow": "#d9c97c",

    "gitDecoration.addedResourceForeground": "#cfd2d8",
    "gitDecoration.modifiedResourceForeground": "#cfd2d8",
    "gitDecoration.deletedResourceForeground": "#db5c5c",
    "gitDecoration.untrackedResourceForeground": "#cfd2d8",
    "gitDecoration.ignoredResourceForeground": "#7b8088",
    "gitDecoration.renamedResourceForeground": "#cfd2d8",
    "gitDecoration.stageModifiedResourceForeground": "#cfd2d8",

    "testing.iconPassed": "#6aab73",
    "testing.iconFailed": "#db5c5c",
    "testing.iconQueued": "#d6b85a",
    "testing.iconUnset": "#7b8088",
    "testing.runAction": "#6aab73",

    "symbolIcon.classForeground": "#cfd2d8",
    "symbolIcon.functionForeground": "#cfd2d8",
    "symbolIcon.interfaceForeground": "#cfd2d8",
    "symbolIcon.methodForeground": "#cfd2d8",
    "symbolIcon.moduleForeground": "#cfd2d8",
    "symbolIcon.namespaceForeground": "#cfd2d8",
    "symbolIcon.packageForeground": "#cfd2d8",
    "symbolIcon.structForeground": "#cfd2d8",
    "symbolIcon.variableForeground": "#bcbec4"
  },
  "tokenColors": [
    {
      "scope": [
        "source",
        "text"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a7e85"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "keyword.control",
        "keyword.operator.word",
        "keyword.other.package.go"
      ],
      "settings": {
        "foreground": "#cf8e6d"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function",
        "meta.function-call entity.name.function",
        "meta.function-call support.function",
        "meta.function-call variable.function"
      ],
      "settings": {
        "foreground": "#bea663"
      }
    },
    {
      "scope": [
        "meta.function entity.name.function",
        "meta.function.declaration entity.name.function",
        "entity.name.function.definition",
        "entity.name.function.go",
        "meta.function.parameters entity.name.function"
      ],
      "settings": {
        "foreground": "#5b9ede"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "storage.type.go",
        "entity.name.type.module.go",
        "support.class.go",
        "entity.name.struct.go"
      ],
      "settings": {
        "foreground": "#79b2c8"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#6aab73"
      }
    },
    {
      "scope": [
        "meta.import string.quoted",
        "meta.import string.quoted.double",
        "meta.import.go string.quoted",
        "meta.import.go string.quoted.double"
      ],
      "settings": {
        "foreground": "#6aab73"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#b5cea8"
      }
    },
    {
      "scope": [
        "entity.name.constant",
        "entity.name.constant.go",
        "variable.other.constant",
        "variable.other.constant.go",
        "support.constant",
        "support.constant.go",
        "meta.const.go entity.name.constant",
        "meta.const.go entity.name.constant.go",
        "meta.const.go variable.other.constant",
        "meta.const.go variable.other.constant.go",
        "meta.const.go support.constant",
        "meta.const.go support.constant.go"
      ],
      "settings": {
        "foreground": "#c189b7"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.other.object",
        "variable.other.readwrite",
        "support.variable",
        "variable.other.property",
        "variable.object.property"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter variable.parameter"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "meta.function.parameters.go variable.parameter",
        "meta.function.arguments.go variable.parameter"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "entity.name.type.package.go",
        "meta.package.go entity.name.package",
        "meta.package.go entity.name.package.go",
        "meta.package.go entity.name.type.package.go",
        "meta.package.go support.type.package.go",
        "meta.package.go entity.name.namespace",
        "meta.package.go entity.name.module"
      ],
      "settings": {
        "foreground": "#a7ac68"
      }
    },
    {
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.type.package.go",
        "meta.path.go",
        "entity.name.package.go",
        "variable.other.package.go",
        "storage.modifier.import.go"
      ],
      "settings": {
        "foreground": "#98ab74"
      }
    },
    {
      "scope": [
        "meta.method.receiver.go variable.parameter",
        "meta.function.receiver.go variable.parameter",
        "meta.receiver.go variable.parameter"
      ],
      "settings": {
        "foreground": "#64a3df"
      }
    },
    {
      "scope": [
        "meta.function-call object",
        "meta.function-call variable.object"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "meta.function-call entity.name.namespace",
        "meta.function-call entity.name.module",
        "meta.function-call.go entity.name.namespace",
        "meta.function-call.go entity.name.module",
        "meta.function-call.method.go entity.name.namespace",
        "meta.function-call.method.go entity.name.module",
        "meta.function-call.go variable.other.package.go",
        "meta.function-call.method.go variable.other.package.go"
      ],
      "settings": {
        "foreground": "#98ab74"
      }
    },
    {
      "scope": [
        "meta.function-call.go",
        "meta.function-call.method.go",
        "meta.function-call support.function.go"
      ],
      "settings": {
        "foreground": "#bea663"
      }
    },
    {
      "scope": [
        "meta.definition.function.go entity.name.function",
        "meta.definition.method.go entity.name.function"
      ],
      "settings": {
        "foreground": "#64a3df"
      }
    },
    {
      "scope": [
        "meta.function-call.go variable.other.member",
        "meta.function-call.go variable.other.property",
        "meta.function-call.go support.variable",
        "meta.function-call.go meta.property-access entity.name.function"
      ],
      "settings": {
        "foreground": "#64a3df"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name",
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#bcbec4"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#79b2c8",
    "class.readonly": "#79b2c8",
    "enum": "#79b2c8",
    "enumMember": "#b5cea8",
    "function": "#bea663",
    "interface": "#79b2c8",
    "keyword": "#cf8e6d",
    "macro": "#bcbec4",
    "method": "#bea663",
    "namespace": "#98ab74",
    "number": "#b5cea8",
    "operator": "#bcbec4",
    "parameter": "#bcbec4",
    "property": "#bcbec4",
    "readonly": "#c189b7",
    "regexp": "#6aab73",
    "string": "#6aab73",
    "struct": "#79b2c8",
    "type": "#79b2c8",
    "typeParameter": "#79b2c8",
    "variable": "#bcbec4",
    "variable.readonly": "#c189b7",
    "variable.defaultLibrary": "#bcbec4",
    "decorator": "#bcbec4",
    "event": "#bcbec4",
    "label": "#bcbec4",
    "member": "#bcbec4",
    "parameter.readonly": "#bcbec4",
    "property.readonly": "#bcbec4",
    "type.defaultLibrary": "#79b2c8",
    "function.declaration": "#4ea1f3",
    "method.declaration": "#4ea1f3",
    "*.declaration": {
      "bold": false
    },
    "*.documentation": {
      "foreground": "#7a7e85",
      "italic": true
    },
    "*.readonly": {
      "foreground": "#bcbec4"
    }
  }
}
