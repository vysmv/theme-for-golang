{
	"name": "theme-for-golang",
	"displayName": "Theme for Golang",
	"description": "A GoLand-inspired dark theme with enhanced Go syntax highlighting.",
	"version": "1.0.0",
	"publisher": "vysmv",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/vysmv/theme-for-golang"
	},
	"homepage": "https://github.com/vysmv/theme-for-golang",
	"bugs": {
		"url": "https://github.com/vysmv/theme-for-golang/issues"
	},
	"main": "./extension.js",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": [
		"Themes",
		"Other"
	],
	"activationEvents": [
		"onCommand:themeForGolang.revealActiveFile",
		"onLanguage:go",
		"onStartupFinished"
	],
	"keywords": [
		"theme",
		"goland",
		"jetbrains",
		"go",
		"dark"
	],
	"contributes": {
		"themes": [
			{
				"label": "Theme for Golang",
				"uiTheme": "vs-dark",
				"path": "./themes/theme-for-golang.json"
			}
		],
		"iconThemes": [
			{
				"id": "theme-for-golang-icons",
        		"label": "Theme for Golang Icons",
				"path": "./icons/goland-exact-icons.json"
			}
		],
		"commands": [
			{
				"command": "themeForGolang.revealActiveFile",
				"title": "Reveal Active File",
				"icon": "$(target)"
			}
		],
		"menus": {
			"view/title": [
				{
					"command": "themeForGolang.revealActiveFile",
					"when": "view == workbench.explorer.fileView",
					"group": "navigation@18"
				}
			]
		}
	},
	"scripts": {
    	"package": "vsce package"
	},
	"icon": "resources/icon.png",
	"galleryBanner": {
		"color": "#2B2D30",
		"theme": "dark"
	},
	"extensionKind": [
		"ui"
	],
	"capabilities": {
		"untrustedWorkspaces": {
			"supported": true
		},
		"virtualWorkspaces": true
	}
}